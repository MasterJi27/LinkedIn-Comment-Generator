{
  "manifest_version": 3,
  "name": "LinkedIn AI Comment & Reply Generator",
  "version": "2.0",
  "description": "Generate and reply to LinkedIn comments using Nvidia Nemotron Super 120B AI via N8N workflow.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://n8n.devflow.me/*",
    "https://n8nworkspace.dpdns.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 